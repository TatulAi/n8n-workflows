        "mode": "runOnceForEachItem",
        "jsCode": "const ai = $json.output || $json;\n\n// Pull the matching original item from the loop by position\nconst loopItems = $('Loop Over Items').all();\nconst idx = $itemIndex;\nconst orig = (loopItems[idx] && loopItems[idx].json) ? loopItems[idx].json : $json;\n\nreturn { json: {\n  messageId: orig.messageId || '',\n  threadId: orig.threadId || '',\n  from: orig.from || '',\n  subject: orig.subject || '',\n  action: ai.action || 'unknown',\n  readState: ai.readState === 'markRead' ? 'markRead' : 'keepUnread',\n  confidence: typeof ai.confidence === 'number' ? ai.confidence : 0,\n  reason: ai.reason || 'no reason returned'\n}};"
