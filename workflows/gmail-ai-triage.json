    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const d = $json;\nconst pick = (...keys) => {\n  for (const k of keys) {\n    if (d[k] !== undefined && d[k] !== null && d[k] !== '') return d[k];\n  }\n  return '';\n};\nconst toStr = (v, name) => {\n  if (!v) return '';\n  let s;\n  if (typeof v === 'string') { s = v; }\n  else if (Array.isArray(v)) { s = v.map(x => x.text || x.address || x.value || (x.name ? `${x.name} <${x.address||''}>` : '')).join(', '); }\n  else if (typeof v === 'object') { s = v.text || v.value || v.address || (v.name ? `${v.name} <${v.address||''}>` : JSON.stringify(v)); }\n  else { s = String(v); }\n  return s.replace(new RegExp('^\\\\s*' + name + ':\\\\s*', 'i'), '').trim();\n};\nconst headers = d.payload?.headers || [];\nconst getHeader = (n) => Array.isArray(headers) ? (headers.find(h => (h.name||'').toLowerCase() === n)?.value || '') : '';\n\nconst subject = toStr(pick('subject', 'Subject'), 'Subject') || getHeader('subject');\nconst from    = toStr(pick('from', 'From'), 'From') || getHeader('from');\nconst to      = toStr(pick('to', 'To'), 'To') || getHeader('to');\nconst listUnsub = toStr(pick('list-unsubscribe', 'listUnsubscribe', 'List-Unsubscribe'), 'List-Unsubscribe') || getHeader('list-unsubscribe');\n\nfunction decode(str){ if(!str) return ''; return Buffer.from(String(str).replace(/-/g,'+').replace(/_/g,'/'),'base64').toString('utf8'); }\nfunction extractBody(payload){\n  if(!payload) return '';\n  if(payload.body?.data) return decode(payload.body.data);\n  if(payload.parts){\n    for(const p of payload.parts){ if(p.mimeType==='text/plain' && p.body?.data) return decode(p.body.data); }\n    for(const p of payload.parts){ const r=extractBody(p); if(r) return r; }\n  }\n  return '';\n}\nlet body = pick('text', 'textPlain') || extractBody(d.payload) || pick('html', 'snippet');\nif (typeof body !== 'string') body = JSON.stringify(body);\nbody = body.replace(/<[^>]+>/g, ' ').replace(/\\s+/g, ' ').trim().slice(0, 4000);\n\nreturn { json: {\n  messageId: d.id || '',\n  threadId: d.threadId || '',\n  subject, from, to,\n  listUnsubscribe: listUnsub,\n  body\n}};"
      },
